## ReadRhythm 프론트엔드 환경변수 예시
## 이 파일을 복사하여 .env 로 저장한 뒤 값을 채우세요.
## cp .env.example .env

# ── 백엔드 서버 ──────────────────────────────────────
# AI 추천·코치 리포트 NestJS 백엔드 (7-2. ReadRhythm-backend)
# 서버 미실행 시 목업 데이터로 자동 폴백됩니다.
EXPO_PUBLIC_BACKEND_URL=http://localhost:3001

# AI 사서 RAG FastAPI 백엔드 (9. AI사서응답시스템)
# 서버 미실행 시 앱 내 오류 메시지가 표시됩니다.
EXPO_PUBLIC_LIBRARIAN_URL=http://localhost:8000

# ── 도서 검색 API (선택) ─────────────────────────────
# 미입력 시 내장 목업 도서 15종으로 자동 폴백됩니다.

# 카카오 도서 API: https://developers.kakao.com/
EXPO_PUBLIC_KAKAO_API_KEY=

# 네이버 책 검색 API: https://developers.naver.com/
EXPO_PUBLIC_NAVER_CLIENT_ID=
EXPO_PUBLIC_NAVER_CLIENT_SECRET=
