## ReadRhythm 환경변수 설정 가이드
## 이 파일을 복사해서 .env 파일을 만드세요: cp .env.example .env
## Expo는 EXPO_PUBLIC_ 접두사 변수만 클라이언트 코드에 노출됩니다.

# ── AI 사서 백엔드 (FastAPI, 포트 8000) ───────────────────────────────────────
# AI 사서 RAG + Claude 추천·코치 모두 여기서 처리
EXPO_PUBLIC_LIBRARIAN_URL=http://localhost:8000


# ── 도서 검색 API ─────────────────────────────────────────────────────────────
# 키가 없으면 15개 샘플 Mock 데이터로 자동 폴백됩니다.
# 카카오 우선 시도 → 실패 시 네이버 → 실패 시 Mock

# [ 카카오 도서 검색 ] ─────────────────────────────────────────────────────────
# 발급 방법:
#   1. https://developers.kakao.com 접속 → 로그인
#   2. [내 애플리케이션] → [애플리케이션 추가하기]
#   3. 앱 이름: ReadRhythm (임의 입력 가능)
#   4. [앱 설정] → [앱 키] → REST API 키 복사
#   5. [제품] → [Daum 검색] → [활성화 설정] ON
# 비용: 무료 (일 30만 건 제한)
EXPO_PUBLIC_KAKAO_API_KEY=

# [ 네이버 도서 검색 ] ─────────────────────────────────────────────────────────
# 발급 방법:
#   1. https://developers.naver.com 접속 → 로그인
#   2. [Application] → [애플리케이션 등록]
#   3. 사용 API: [검색] 체크
#   4. 비로그인 오픈 API → Client ID / Client Secret 복사
# 비용: 무료 (일 25,000건 제한)
EXPO_PUBLIC_NAVER_CLIENT_ID=
EXPO_PUBLIC_NAVER_CLIENT_SECRET=
