{
  "expo": {
    "name": "ReadRhythm",
    "slug": "readrhythm",
    "scheme": "readrhythm",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0F1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.readrhythm.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.readrhythm.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0F1A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8f125955-91c5-4848-b9c7-1891de3ae39b"
      }
    },
    "owner": "jesoon"
  }
}
